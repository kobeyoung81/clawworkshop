{
  "project_type": {
    "id": "software_feature_project",
    "name": "Software Feature Project",
    "version": "1.0.0",
    "description": "A project type for delivering a software feature end-to-end using AI agents with human review gates.",
    "execution_mode": "auto",
    "parameters": [
      {
        "id": "primary_language",
        "type": "string",
        "required": false,
        "default": "TypeScript",
        "description": "Primary implementation language for the feature"
      },
      {
        "id": "require_architecture_review",
        "type": "boolean",
        "required": false,
        "default": true,
        "description": "Whether an architecture review step is included"
      }
    ],
    "roles": [
      {
        "id": "human_owner",
        "kind": "human",
        "description": "Human project owner who provides direction, reviews outputs, and approves deliverables.",
        "default_prompt": "You are the project owner. Provide clear direction and apply sound judgment when reviewing outputs.",
        "allowed_task_types": ["provide_brief", "review_prd", "review_architecture", "review_code"]
      },
      {
        "id": "prd_agent",
        "kind": "agent",
        "description": "AI agent that drafts product requirements documents from a brief.",
        "default_prompt": "You are a senior product manager. Produce a clear, complete, and actionable PRD based on the provided brief.",
        "allowed_task_types": ["draft_prd", "revise_prd"]
      },
      {
        "id": "architect_agent",
        "kind": "agent",
        "description": "AI agent that produces architecture documents from approved PRDs.",
        "default_prompt": "You are a senior software architect. Produce a pragmatic, well-reasoned architecture document covering components, interfaces, data flow, and key tradeoffs.",
        "allowed_task_types": ["design_architecture", "revise_architecture"]
      },
      {
        "id": "coding_agent",
        "kind": "agent",
        "description": "AI agent that implements code from approved architecture documents.",
        "default_prompt": "You are a senior software engineer. Produce clean, maintainable, correct, and well-tested code according to the architecture document.",
        "allowed_task_types": ["implement_code", "revise_code"]
      }
    ],
    "artifact_types": [
      {
        "id": "brief_doc",
        "description": "Initial project brief provided by the human owner",
        "content_kind": "markdown"
      },
      {
        "id": "prd_doc",
        "description": "Product requirements document",
        "content_kind": "markdown"
      },
      {
        "id": "architecture_doc",
        "description": "System architecture design document",
        "content_kind": "markdown"
      },
      {
        "id": "code_bundle",
        "description": "Implemented code files for the feature",
        "content_kind": "bundle"
      },
      {
        "id": "review_feedback",
        "description": "Structured review feedback from a review node",
        "content_kind": "text"
      }
    ],
    "task_types": [
      {
        "id": "provide_brief",
        "description": "Human owner provides the initial project brief",
        "allowed_roles": ["human_owner"],
        "inputs": [],
        "outputs": [
          { "name": "brief", "artifact_type": "brief_doc" }
        ],
        "default_prompt": "Provide a clear project brief describing the goal, scope, constraints, and success criteria."
      },
      {
        "id": "draft_prd",
        "description": "Draft a product requirements document from the project brief",
        "allowed_roles": ["prd_agent"],
        "inputs": [
          { "name": "brief", "artifact_type": "brief_doc", "required": true }
        ],
        "outputs": [
          { "name": "prd", "artifact_type": "prd_doc" }
        ],
        "default_prompt": "Produce a complete PRD covering goals, user stories, functional requirements, non-functional requirements, and out-of-scope items."
      },
      {
        "id": "review_prd",
        "description": "Review the drafted PRD and approve or request revisions",
        "allowed_roles": ["human_owner"],
        "inputs": [
          { "name": "prd", "artifact_type": "prd_doc", "required": true }
        ],
        "outputs": [
          { "name": "feedback", "artifact_type": "review_feedback" }
        ],
        "default_prompt": "Review the PRD for completeness, clarity, and correctness. Approve if satisfactory, or request revisions with specific feedback."
      },
      {
        "id": "revise_prd",
        "description": "Revise the PRD based on review feedback",
        "allowed_roles": ["prd_agent"],
        "inputs": [
          { "name": "prd", "artifact_type": "prd_doc", "required": true },
          { "name": "feedback", "artifact_type": "review_feedback", "required": true }
        ],
        "outputs": [
          { "name": "prd", "artifact_type": "prd_doc" }
        ],
        "default_prompt": "Revise the PRD based on the review feedback. Address all requested changes precisely."
      },
      {
        "id": "design_architecture",
        "description": "Produce an architecture document from an approved PRD",
        "allowed_roles": ["architect_agent"],
        "inputs": [
          { "name": "prd", "artifact_type": "prd_doc", "required": true }
        ],
        "outputs": [
          { "name": "architecture", "artifact_type": "architecture_doc" }
        ],
        "default_prompt": "Produce a pragmatic architecture document covering key components, their interfaces, data flow, storage strategy, and major design tradeoffs."
      },
      {
        "id": "review_architecture",
        "description": "Review the architecture document and approve or request revisions",
        "allowed_roles": ["human_owner"],
        "inputs": [
          { "name": "architecture", "artifact_type": "architecture_doc", "required": true }
        ],
        "outputs": [
          { "name": "feedback", "artifact_type": "review_feedback" }
        ],
        "default_prompt": "Review the architecture for soundness, practicality, and alignment with the PRD. Approve if satisfactory, or request revisions."
      },
      {
        "id": "revise_architecture",
        "description": "Revise the architecture document based on review feedback",
        "allowed_roles": ["architect_agent"],
        "inputs": [
          { "name": "architecture", "artifact_type": "architecture_doc", "required": true },
          { "name": "feedback", "artifact_type": "review_feedback", "required": true }
        ],
        "outputs": [
          { "name": "architecture", "artifact_type": "architecture_doc" }
        ],
        "default_prompt": "Revise the architecture based on the review feedback. Address all requested changes precisely."
      },
      {
        "id": "implement_code",
        "description": "Implement the feature code from the approved architecture",
        "allowed_roles": ["coding_agent"],
        "inputs": [
          { "name": "architecture", "artifact_type": "architecture_doc", "required": true }
        ],
        "outputs": [
          { "name": "code", "artifact_type": "code_bundle" }
        ],
        "default_prompt": "Implement the feature according to the architecture document. Write clean, maintainable, well-tested code."
      },
      {
        "id": "review_code",
        "description": "Review the implemented code and approve or request revisions",
        "allowed_roles": ["human_owner"],
        "inputs": [
          { "name": "code", "artifact_type": "code_bundle", "required": true }
        ],
        "outputs": [
          { "name": "feedback", "artifact_type": "review_feedback" }
        ],
        "default_prompt": "Review the code for correctness, quality, and alignment with the architecture. Approve if satisfactory, or request revisions."
      },
      {
        "id": "revise_code",
        "description": "Revise the code based on review feedback",
        "allowed_roles": ["coding_agent"],
        "inputs": [
          { "name": "code", "artifact_type": "code_bundle", "required": true },
          { "name": "feedback", "artifact_type": "review_feedback", "required": true }
        ],
        "outputs": [
          { "name": "code", "artifact_type": "code_bundle" }
        ],
        "default_prompt": "Revise the code based on the review feedback. Address all requested changes precisely."
      }
    ],
    "workflow_types": [
      {
        "id": "feature_delivery_flow",
        "description": "End-to-end workflow for delivering a software feature with PRD, architecture, and code review gates",
        "nodes": [
          {
            "id": "provide_brief_node",
            "kind": "input",
            "task_type": "provide_brief",
            "role": "human_owner",
            "title": "Provide Project Brief"
          },
          {
            "id": "draft_prd_node",
            "kind": "work",
            "task_type": "draft_prd",
            "role": "prd_agent",
            "title": "Draft PRD",
            "sprint_eligible": true
          },
          {
            "id": "review_prd_node",
            "kind": "review",
            "task_type": "review_prd",
            "role": "human_owner",
            "title": "Review PRD"
          },
          {
            "id": "design_architecture_node",
            "kind": "work",
            "task_type": "design_architecture",
            "role": "architect_agent",
            "title": "Design Architecture",
            "sprint_eligible": true
          },
          {
            "id": "review_architecture_node",
            "kind": "review",
            "task_type": "review_architecture",
            "role": "human_owner",
            "title": "Review Architecture"
          },
          {
            "id": "implement_code_node",
            "kind": "work",
            "task_type": "implement_code",
            "role": "coding_agent",
            "title": "Implement Code",
            "sprint_eligible": true
          },
          {
            "id": "review_code_node",
            "kind": "review",
            "task_type": "review_code",
            "role": "human_owner",
            "title": "Review Code"
          },
          {
            "id": "end_node",
            "kind": "end",
            "title": "Feature Delivered"
          }
        ],
        "edges": [
          {
            "from": "provide_brief_node",
            "to": "draft_prd_node",
            "on": "completed",
            "artifact_map": [
              { "from_output": "brief", "to_input": "brief" }
            ]
          },
          {
            "from": "draft_prd_node",
            "to": "review_prd_node",
            "on": "completed",
            "artifact_map": [
              { "from_output": "prd", "to_input": "prd" }
            ]
          },
          {
            "from": "review_prd_node",
            "to": "design_architecture_node",
            "on": "approved",
            "artifact_map": [
              { "from_input": "prd", "to_input": "prd" }
            ]
          },
          {
            "from": "review_prd_node",
            "to": "draft_prd_node",
            "on": "revise",
            "artifact_map": [
              { "from_input": "prd", "to_input": "prd" },
              { "from_output": "feedback", "to_input": "feedback" }
            ]
          },
          {
            "from": "design_architecture_node",
            "to": "review_architecture_node",
            "on": "completed",
            "artifact_map": [
              { "from_output": "architecture", "to_input": "architecture" }
            ]
          },
          {
            "from": "review_architecture_node",
            "to": "implement_code_node",
            "on": "approved",
            "artifact_map": [
              { "from_input": "architecture", "to_input": "architecture" }
            ]
          },
          {
            "from": "review_architecture_node",
            "to": "design_architecture_node",
            "on": "revise",
            "artifact_map": [
              { "from_input": "architecture", "to_input": "architecture" },
              { "from_output": "feedback", "to_input": "feedback" }
            ]
          },
          {
            "from": "implement_code_node",
            "to": "review_code_node",
            "on": "completed",
            "artifact_map": [
              { "from_output": "code", "to_input": "code" }
            ]
          },
          {
            "from": "review_code_node",
            "to": "end_node",
            "on": "approved",
            "artifact_map": []
          },
          {
            "from": "review_code_node",
            "to": "implement_code_node",
            "on": "revise",
            "artifact_map": [
              { "from_input": "code", "to_input": "code" },
              { "from_output": "feedback", "to_input": "feedback" }
            ]
          }
        ]
      }
    ]
  }
}
